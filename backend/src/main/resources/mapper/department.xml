<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lms.mapper.DepartmentMapper">

    <!-- 학과 고유 번호(PK)로 학과 상세 정보 조회 -->
    <select id="selectDepartmentByDeptId" resultType="com.lms.entity.Department">
        SELECT ID
             , DEPT_NAME
          FROM DEPARTMENTS
         WHERE ID = #{deptId}
    </select>
</mapper>