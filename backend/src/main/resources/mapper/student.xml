<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lms.mapper.StudentMapper">
    <resultMap id="UserResultMap" type="com.lms.entity.PrincipalUser">
        <id property="id" column="ID" />
        <result property="userId" column="STUDENT_NO"/>
        <result property="password" column="PASSWORD"/>
        <result property="name" column="NAME"/>
        <result property="role" column="ROLE"/>
    </resultMap>

    <!-- 아이디로 학생 개인정보 조회 -->
    <select id="selectStudentInfoByStudentNo" resultMap="UserResultMap">
        SELECT ID
             , STUDENT_NO
             , PASSWORD
             , NAME
             , ROLE
          FROM STUDENTS
         WHERE STUDENT_NO = #{studentNo}
    </select>

</mapper>